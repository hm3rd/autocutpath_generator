<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
  <name>AutoCutPath</name>
  <id>com.blogspot.inkscape-memorandum.AutoCutPath</id>
  <effect>
    <effects-menu>
      <submenu name="AutoCutPath"/>
    </effects-menu>
  </effect>
  <script>
    <command location="inx" interpreter="python">auto_cut_path.py</command>
  </script>
</inkscape-extension>